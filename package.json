{
  "name": "nail-couture",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @nail-couture/web",
    "dev:web": "npm run dev -w @nail-couture/web",
    "dev:mobile": "npm run start -w @nail-couture/mobile",
    "build:mobile:ios": "npm run build:dev:ios -w @nail-couture/mobile",
    "build:mobile:android": "npm run build:dev:android -w @nail-couture/mobile",
    "build": "npm run build -w @nail-couture/web",
    "build:web": "npm run build -w @nail-couture/web",
    "build:capacitor": "npm run build -w @nail-couture/web && npm run sync -w @nail-couture/capacitor",
    "sync:capacitor": "npm run sync -w @nail-couture/capacitor",
    "cap:ios": "npm run open:ios -w @nail-couture/capacitor",
    "cap:android": "npm run open:android -w @nail-couture/capacitor",
    "build:capacitor-couture": "npm run build -w @nail-couture/web && npm run sync -w @nail-couture/capacitor-couture",
    "sync:capacitor-couture": "npm run sync -w @nail-couture/capacitor-couture",
    "cap:couture:ios": "npm run open:ios -w @nail-couture/capacitor-couture",
    "cap:couture:android": "npm run open:android -w @nail-couture/capacitor-couture",
    "lint": "npm run lint -w @nail-couture/web"
  }
}
